# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=ariosetech

# Admin Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
ADMIN_JWT_SECRET=generate-with-openssl-rand-hex-32

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Verified sender. The domain must be verified in your Resend dashboard.
EMAIL_FROM=ARIOSETECH <noreply@ariosetech.com>
# Where contact-form notifications are delivered.
EMAIL_TO=info@ariosetech.com

# Site
NEXT_PUBLIC_SITE_URL=https://ariosetech.com

# SEO Auditor — optional AI content review (uses Anthropic API)
# Without this, the technical checks still work fully.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
